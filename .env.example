# --- Ask AI -----------------------------------------------
# Set OPENAI_API_KEY to enable the "Ask AI" button in the
# docs layout. When unset, the button is hidden and
# /api/chat returns 503 (defense in depth).
OPENAI_API_KEY=

# Optional — defaults to 'gpt-4o-mini'. Any chat-completion
# model supported by @ai-sdk/openai works.
# OPENAI_MODEL=gpt-4o-mini

# --- Site URL (used in OG image links) ---------------------
# NEXT_PUBLIC_SITE_URL=https://docs.getaphex.com
